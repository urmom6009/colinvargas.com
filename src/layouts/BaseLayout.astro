---
import "../styles/global.css";

const {
  title = "colin vargas - computational aerospace engineering",
  description = "Computational fluid dynamics, propulsion, and numerical methods."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f3ed" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
