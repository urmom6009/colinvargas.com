---
import BaseLayout from "../layouts/BaseLayout.astro";

const work = [
  {
    title: "adaptive cfd solver",
    meta: "thesis / amrex / c++ / finite volume",
    detail:
      "solver path from scalar advection toward adaptive flow capability, built through small verification cases.",
    href: "/work/adaptive-cfd-solver"
  },
  {
    title: "scramjet analysis tool",
    meta: "python / propulsion / parametric analysis",
    detail:
      "propulsion trade-space tooling that makes assumptions, sweeps, and trends easier to inspect.",
    href: "/work/scramjet-analysis-tool"
  },
  {
    title: "compressible flow project",
    meta: "numerical methods / visualization / paraview",
    detail:
      "finite-volume simulations and post-processing workflows with reproducible context around the figures.",
    href: "/work/compressible-flow-project"
  },
  {
    title: "repo-aware technical log workflow",
    meta: "astro content / node script / documentation",
    detail:
      "command-line workflow that turns local engineering work into dated notes and attachment folders.",
    href: "/notes"
  },
  {
    title: "portfolio site and deployment pipeline",
    meta: "astro / vercel / github / cloudflare",
    detail:
      "static portfolio with custom-domain dns, changelog discipline, and local build verification.",
    href: "/"
  }
];

const capabilities = [
  "finite-volume methods",
  "adaptive mesh refinement",
  "c++ solver development",
  "python analysis tooling",
  "propulsion trade studies",
  "verification workflows",
  "paraview post-processing",
  "technical documentation"
];

const contacts = [
  { label: "github", detail: "source history", href: "https://github.com/colinvargas" },
  { label: "linkedin", detail: "profile context", href: "https://www.linkedin.com/in/colinvargas" },
  { label: "email", detail: "hello@colinvargas.com", href: "mailto:hello@colinvargas.com" }
];
---

<BaseLayout title="resume - colin vargas">
  <header class="site-header">
    <a class="brand" href="/" aria-label="colin vargas home">colin vargas</a>
    <nav aria-label="primary navigation">
      <a href="/work">work</a>
      <a href="/notes">notes</a>
      <a href="/resume" aria-current="page">resume</a>
      <a href="/about">about</a>
      <a href="/contact">contact</a>
    </nav>
  </header>

  <main>
    <section class="resume-hero" aria-labelledby="resume-title">
      <div class="section-heading">
        <span>resume</span>
        <span>computational aerospace</span>
      </div>

      <div class="resume-hero-grid">
        <div>
          <h1 id="resume-title">colin vargas</h1>
          <p>
            aerospace engineering, numerical methods, propulsion, and software
            for turning complex physical behavior into something inspectable.
          </p>
        </div>

        <aside>
          <span>current focus</span>
          <strong>amrex-based solver development</strong>
          <p>scalar advection, verification, adaptive flow capability, and records that can be reopened later.</p>
        </aside>
      </div>
    </section>

    <section class="resume-section" aria-labelledby="resume-work-title">
      <div class="section-heading">
        <span id="resume-work-title">work index</span>
        <span>linked artifacts</span>
      </div>

      <div class="resume-list">
        {
          work.map((item, index) => (
            <a class="resume-item" href={item.href} data-build-step={index + 1}>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <div>
                <h2>{item.title}</h2>
                <p>{item.detail}</p>
              </div>
              <strong>{item.meta}</strong>
            </a>
          ))
        }
      </div>
    </section>

    <section class="resume-section" aria-labelledby="capabilities-title">
      <div class="section-heading">
        <span id="capabilities-title">capabilities</span>
        <span>technical surface</span>
      </div>

      <ul class="capability-grid" aria-label="capabilities">
        {capabilities.map((capability, index) => <li data-build-step={index + 1}>{capability}</li>)}
      </ul>
    </section>

    <section class="resume-section resume-contact" aria-labelledby="resume-contact-title">
      <div class="section-heading">
        <span id="resume-contact-title">contact</span>
        <span>public links</span>
      </div>

      <div class="resume-contact-grid">
        {
          contacts.map((contact, index) => (
            <a href={contact.href} data-build-step={index + 1}>
              <span>{contact.label}</span>
              <strong>{contact.detail}</strong>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
