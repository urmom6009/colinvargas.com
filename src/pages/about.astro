---
import BaseLayout from "../layouts/BaseLayout.astro";

const principles = [
  "small verification cases before ambitious simulations",
  "interfaces that keep math, mesh, state, and output honest",
  "plots and notes that explain decisions, not just results"
];
---

<BaseLayout title="about - colin vargas">
  <header class="site-header">
    <a class="brand" href="/" aria-label="colin vargas home">colin vargas</a>
    <nav aria-label="primary navigation">
      <a href="/work">work</a>
      <a href="/notes">notes</a>
      <a href="/resume">resume</a>
      <a href="/about" aria-current="page">about</a>
      <a href="/contact">contact</a>
    </nav>
  </header>

  <main>
    <section class="resume-hero" aria-labelledby="about-title">
      <div class="section-heading">
        <span>about</span>
        <span>visible reasoning</span>
      </div>

      <div class="resume-hero-grid">
        <div>
          <h1 id="about-title">work should survive being reopened.</h1>
          <p>
            the center of gravity is computational aerospace: numerical methods,
            propulsion, and software that turns physical behavior into something
            testable instead of merely impressive.
          </p>
        </div>

        <aside>
          <span>technical taste</span>
          <strong>math, code, and intuition all in the same room</strong>
          <p>this site is a public bench for projects once the record is clear enough to be useful: heavy type, quiet diagrams, blunt notes, useful proof.</p>
        </aside>
      </div>
    </section>

    <section class="resume-section" aria-labelledby="principles-title">
      <div class="section-heading">
        <span id="principles-title">principles</span>
        <span>build behavior</span>
      </div>

      <ul class="capability-grid" aria-label="working principles">
        {principles.map((principle) => <li>{principle}</li>)}
      </ul>
    </section>
  </main>
</BaseLayout>
