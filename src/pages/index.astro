---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    title: "adaptive cfd solver",
    meta: "thesis / amrex / c++",
    status: "active build log",
    desc: "Scalar advection first, then AMR and higher-order pieces as they earn their place.",
    href: "/work/adaptive-cfd-solver"
  },
  {
    title: "scramjet analysis tool",
    meta: "python / propulsion / parametric analysis",
    status: "writeup pending",
    desc: "A Python tool for sweeping assumptions and seeing which inputs actually move the result.",
    href: "/work/scramjet-analysis-tool"
  },
  {
    title: "compressible flow project",
    meta: "numerical methods / visualization / paraview",
    status: "archive pending",
    desc: "Simulation setup, plots, and numerical behavior kept together instead of scattered across files.",
    href: "/work/compressible-flow-project"
  }
];

const readout = [
  { label: "scheme", value: "fv / explicit" },
  { label: "case", value: "scalar advection" },
  { label: "next", value: "amr verification" }
];

const trajectory = [
  {
    step: "01",
    title: "baseline physics",
    detail: "Keep the first cases small enough to inspect every numerical choice."
  },
  {
    step: "02",
    title: "solver architecture",
    detail: "Separate mesh, state, flux, and update paths so the system can grow cleanly."
  },
  {
    step: "03",
    title: "public record",
    detail: "Publish the plots, notes, and verification trail once they clarify the work."
  }
];

const signal = [
  { label: "numerics", value: "make the simple case hard to fool" },
  { label: "propulsion", value: "sweep assumptions before trusting a point design" },
  { label: "software", value: "keep the run easy to rerun" }
];

const methods = [
  {
    label: "discretize",
    meta: "start small",
    detail: "The first case should be simple enough that a wrong answer has nowhere to hide."
  },
  {
    label: "verify",
    meta: "show the checks",
    detail: "A plot is more useful when the setup, assumptions, and failure modes are beside it."
  },
  {
    label: "publish",
    meta: "write after the work",
    detail: "Pages stay short until there is something concrete to explain."
  }
];

const links = [
  { label: "github", href: "https://github.com/colinvargas" },
  { label: "linkedin", href: "https://www.linkedin.com/in/colinvargas" },
  { label: "email", href: "mailto:hello@colinvargas.com" }
];
---

<BaseLayout>
  <div class="field" aria-hidden="true">
    <span class="mach mach-one"></span>
    <span class="mach mach-two"></span>
    <span class="patch patch-one"></span>
    <span class="patch patch-two"></span>
  </div>

  <header class="site-header">
    <a class="brand" href="/" aria-label="colin vargas home">colin vargas</a>
    <nav aria-label="Primary navigation">
      <a href="/work">work</a>
      <a href="/notes">notes</a>
      <a href="/resume">resume</a>
      <a href="/about">about</a>
      <a href="/contact">contact</a>
    </nav>
  </header>

  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-grid">
        <div class="hero-copy">
          <h1 id="hero-title">computational aerospace systems.</h1>
          <p class="intro">
            CFD, propulsion analysis, and the kind of code that makes a
            calculation easier to rerun, question, and explain.
          </p>
        </div>

        <aside class="hero-panel" aria-label="Current status">
          <span>current track</span>
          <strong>AMReX solver development</strong>
          <p>
            Scalar advection now. AMR and higher-order pieces next, once the
            baseline is clean.
          </p>

          <div class="solver-readout" aria-label="Solver readout">
            <div class="readout-plot" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <dl>
              {
                readout.map((item) => (
                  <div>
                    <dt>{item.label}</dt>
                    <dd>{item.value}</dd>
                  </div>
                ))
              }
            </dl>
          </div>
        </aside>
      </div>

      <div class="method-lab" data-method-lab aria-label="Working method selector">
        <div class="method-copy">
          <span>working method</span>
          <strong data-method-title>{methods[0].meta}</strong>
          <p data-method-detail>{methods[0].detail}</p>
        </div>

        <div class="method-controls" aria-label="Choose a working method">
          {
            methods.map((method, index) => (
              <button
                type="button"
                class="method-control"
                data-method-index={index}
                data-method-meta={method.meta}
                data-method-detail={method.detail}
                aria-pressed={index === 0 ? "true" : "false"}
              >
                <span>{String(index + 1).padStart(2, "0")}</span>
                <strong>{method.label}</strong>
              </button>
            ))
          }
        </div>
      </div>

      <ul class="tags" aria-label="Technical focus areas">
        <li>amrex</li>
        <li>c++</li>
        <li>finite volume</li>
        <li>adaptive mesh refinement</li>
        <li>verification</li>
      </ul>
    </section>

    <section class="signature" aria-labelledby="signature-title">
      <div class="signature-copy">
        <div class="section-heading">
          <span id="signature-title">signal</span>
          <span>engineering taste</span>
        </div>
        <p>
          I like work where the math, the code, and the physical intuition are
          close enough together to catch each other.
        </p>
      </div>

      <div class="signature-board" aria-label="Technical signal board">
        <div class="signature-equation">
          <span>u_t + div F(u) = 0</span>
          <span>dt &lt;= cfl * dx / max(|lambda|)</span>
        </div>
        <div class="signature-wave" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
          <span></span>
        </div>
        <dl>
          {
            signal.map((item) => (
              <div>
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <section class="section" id="work" aria-labelledby="work-title">
      <div class="section-heading">
        <span id="work-title">selected work</span>
        <span><a href="/work">full index</a></span>
      </div>

      <div class="project-grid">
        {
          projects.map((project) => (
            <a class="project-card" href={project.href}>
              <span class="project-meta">{project.meta}</span>
              <h2>{project.title}</h2>
              <p>{project.desc}</p>
              <span class="project-status">{project.status}</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="focus" aria-labelledby="focus-title">
      <div class="section-heading">
        <span id="focus-title">current focus</span>
        <span>thesis track</span>
      </div>
      <p>
        Developing a solver and project record where the numerical choices,
        checks, and tradeoffs are visible without overselling the result.
      </p>
    </section>

    <section class="trajectory" aria-labelledby="trajectory-title">
      <div class="section-heading">
        <span id="trajectory-title">solver trajectory</span>
        <span>from case to record</span>
      </div>

      <div class="trajectory-grid">
        <div class="trajectory-map" aria-hidden="true">
          <span class="map-line"></span>
          <span class="map-node map-node-one"></span>
          <span class="map-node map-node-two"></span>
          <span class="map-node map-node-three"></span>
          <span class="map-sweep map-sweep-one"></span>
          <span class="map-sweep map-sweep-two"></span>
        </div>

        <div class="trajectory-list">
          {
            trajectory.map((item) => (
              <article>
                <span>{item.step}</span>
                <h2>{item.title}</h2>
                <p>{item.detail}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="evidence" aria-labelledby="evidence-title">
      <div class="section-heading">
        <span id="evidence-title">working style</span>
        <span>repeatable records</span>
      </div>
      <div class="evidence-list">
        <article>
          <span>01</span>
          <h2>Build the calculation.</h2>
          <p>Start with working local tools, small verification cases, and source history that can be replayed.</p>
        </article>
        <article>
          <span>02</span>
          <h2>Expose the assumptions.</h2>
          <p>Document boundary conditions, discretization choices, solver limits, and what changed between runs.</p>
        </article>
        <article>
          <span>03</span>
          <h2>Publish the useful record.</h2>
          <p>Turn notes, plots, and project logs into public pages only when they help someone inspect the work.</p>
        </article>
      </div>
    </section>

    <section class="split" aria-label="Notes and profile">
      <article>
        <div class="section-heading">
          <span>notes</span>
          <span><a href="/notes">open log index</a></span>
        </div>
        <p>
          A repo-aware log workflow is in place. Public notes will appear as
          project entries are cleaned up with enough context to be useful.
        </p>
      </article>

      <article>
        <div class="section-heading">
          <span>about</span>
          <span>systems reasoning</span>
        </div>
        <p>
          Aerospace engineering, numerical methods, propulsion, and the habit of turning
          complex physical behavior into inspectable computational tools.
        </p>
      </article>
    </section>
  </main>

  <footer>
    <span>america/phoenix</span>
    <div class="footer-links">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </div>
  </footer>
  <script>
    const lab = document.querySelector<HTMLElement>("[data-method-lab]");
    const title = lab?.querySelector<HTMLElement>("[data-method-title]");
    const detail = lab?.querySelector<HTMLElement>("[data-method-detail]");
    const controls = lab?.querySelectorAll<HTMLElement>("[data-method-index]");

    controls?.forEach((control) => {
      control.addEventListener("click", () => {
        controls.forEach((item) => item.setAttribute("aria-pressed", "false"));
        control.setAttribute("aria-pressed", "true");
        lab?.style.setProperty("--method-index", control.dataset.methodIndex || "0");

        if (title && control.dataset.methodMeta) {
          title.textContent = control.dataset.methodMeta;
        }

        if (detail && control.dataset.methodDetail) {
          detail.textContent = control.dataset.methodDetail;
        }
      });
    });
  </script>
</BaseLayout>
