---
import BaseLayout from "../layouts/BaseLayout.astro";
import katex from "katex";
import "katex/dist/katex.min.css";

const conservationLaw = katex.renderToString(String.raw`\partial_t u + \nabla \cdot F(u) = 0`, {
  displayMode: true,
  throwOnError: false
});

const cflCondition = katex.renderToString(String.raw`\Delta t \le C_{\mathrm{CFL}}\frac{\Delta x}{\max |\lambda|}`, {
  displayMode: false,
  throwOnError: false
});

const projects = [
  {
    title: "adaptive cfd solver",
    meta: "thesis / amrex / c++",
    status: "active notebook",
    desc: "scalar advection work kept small enough for boundary conditions, updates, and plots to stay inspectable.",
    lens: "mesh, state, flux, update",
    href: "/work/adaptive-cfd-solver"
  },
  {
    title: "scramjet analysis tool",
    meta: "python / propulsion / parametric analysis",
    status: "writeup pending",
    desc: "propulsion sweeps shaped around assumptions, trends, and comparisons that can be argued with.",
    lens: "assumption, sweep, trend",
    href: "/work/scramjet-analysis-tool"
  },
  {
    title: "compressible flow project",
    meta: "numerical methods / visualization / paraview",
    status: "archive pending",
    desc: "finite-volume outputs paired with enough provenance for the figure to mean something later.",
    lens: "finite-volume inspection",
    href: "/work/compressible-flow-project"
  }
];

const specimens = [
  {
    label: "solver surface",
    title: "start with small cases",
    copy: "keep boundary conditions, fluxes, and updates visible before the case grows.",
    meta: "fv / explicit / cfl 0.42",
    bars: [38, 70, 54, 82]
  },
  {
    label: "mesh pass",
    title: "compare the refined case",
    copy: "tighten the same setup and record which numerical choices start to matter.",
    meta: "limited / refined mesh / cfl 0.31",
    bars: [68, 44, 78, 60]
  },
  {
    label: "stability readout",
    title: "mark the stability limit",
    copy: "increase the step size and record where the run becomes unreliable.",
    meta: "steep front / boundary watch / cfl 0.88",
    bars: [82, 48, 64, 88]
  }
];

const trajectory = [
  {
    step: "01",
    title: "make it inspectable",
    detail: "keep first cases small enough to check by hand and by plot.",
    state: "small verification case"
  },
  {
    step: "02",
    title: "separate the hard parts",
    detail: "let mesh, state, flux, and update paths carry their own responsibilities.",
    state: "separate solver modules"
  },
  {
    step: "03",
    title: "leave a record",
    detail: "publish notes and figures when they explain the decision, not just the result.",
    state: "notes and figures"
  }
];

const signal = [
  { label: "numerics", value: "stability before runtime tuning" },
  { label: "propulsion", value: "trade spaces with stated assumptions" },
  { label: "software", value: "systems that can be reopened later" },
  { label: "taste", value: "plain pages with enough technical detail" }
];
---

<BaseLayout>
  <script is:inline>
    document.documentElement.classList.add("reveal-enabled");
  </script>

  <header class="site-header">
    <a class="brand" href="/" aria-label="colin vargas home">colin vargas</a>
    <nav aria-label="primary navigation">
      <a href="/work">work</a>
      <a href="/notes">notes</a>
      <a href="/resume">resume</a>
      <a href="/about">about</a>
      <a href="/contact">contact</a>
    </nav>
  </header>

  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-copy">
        <h1 id="hero-title" class="hero-title">
          <span>colin</span>
          <span>vargas</span>
        </h1>
        <p class="intro">
          evidence-first aerospace software for numerical tools, solver experiments,
          and project records that make physical behavior easier to inspect.
        </p>
        <aside class="hero-focus">
          <span>current focus</span>
          <strong>solver development, verification, and project notes kept in one place.</strong>
          <p>thesis track / amrex / scalar advection toward adaptive flow capability</p>
        </aside>
      </div>

      <div class="hero-specimen" aria-label="homepage technical specimen">
        <div class="specimen-equation">
          <span set:html={conservationLaw}></span>
          <span set:html={cflCondition}></span>
        </div>
        <p>
          computational aerospace / numerical methods / propulsion / technical records
        </p>
      </div>

      <ul class="hero-tags" aria-label="technical focus areas">
        <li>amrex</li>
        <li>c++</li>
        <li>finite volume</li>
        <li>adaptive mesh refinement</li>
        <li>verification</li>
      </ul>
    </section>

    <section class="story-section showreel" id="specimens" aria-labelledby="showreel-title" data-scroll-chapter>
      <div class="section-lead">
        <div class="section-heading" data-reveal>
          <span id="showreel-title">solver specimens</span>
          <span>scroll readout</span>
        </div>
        <p class="section-idea" data-reveal>small calculations are easier to verify.</p>
      </div>

      <div class="section-details specimen-stack">
        {
          specimens.map((item, index) => (
            <article class="specimen-card" data-build-step={index + 1}>
              <div class="specimen-card-copy">
                <span>{item.label}</span>
                <h2>{item.title}</h2>
                <p>{item.copy}</p>
              </div>
              <div class="specimen-meter" aria-hidden="true">
                {item.bars.map((height) => <span style={`--meter-height: ${height}%`}></span>)}
              </div>
              <p class="specimen-meta">{item.meta}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="story-section signature" aria-labelledby="signature-title" data-scroll-chapter>
      <div class="section-lead signature-copy">
        <div class="section-heading" data-reveal>
          <span id="signature-title">signal</span>
          <span>engineering taste</span>
        </div>
        <p class="section-idea" data-reveal>
          useful signal comes from math, code, and the physical system agreeing enough to explain.
        </p>
      </div>

      <div class="section-details">
        <div class="signature-board" aria-label="technical signal board" data-build-step="1">
          <div class="signature-wave" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
          <dl>
            {
              signal.map((item) => (
                <div>
                  <dt>{item.label}</dt>
                  <dd>{item.value}</dd>
                </div>
              ))
            }
          </dl>
        </div>
      </div>
    </section>

    <section class="story-section work-show" id="work" aria-labelledby="work-title" data-scroll-chapter>
      <div class="section-lead">
        <div class="section-heading" data-reveal>
          <span id="work-title">selected work</span>
          <span><a href="/work">full index</a></span>
        </div>
        <p class="section-idea" data-reveal>selected work is organized around evidence.</p>
      </div>

      <div class="section-details work-list">
        {
          projects.map((project, index) => (
            <a class="work-card" href={project.href} data-build-step={index + 1}>
              <span class="project-meta">{project.meta}</span>
              <h2>{project.title}</h2>
              <p>{project.desc}</p>
              <span class="project-lens">{project.lens}</span>
              <span class="project-status">{project.status}</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="story-section trajectory" aria-labelledby="trajectory-title" data-scroll-chapter>
      <div class="section-lead">
        <div class="section-heading" data-reveal>
          <span id="trajectory-title">solver trajectory</span>
          <span>from case to record</span>
        </div>
        <p class="section-idea" data-reveal>the record shows what each part is responsible for.</p>
      </div>

      <div class="section-details trajectory-grid">
        <div class="trajectory-map" aria-hidden="true" data-build-step="1">
          <span class="map-line"></span>
          <span class="map-node map-node-one"></span>
          <span class="map-node map-node-two"></span>
          <span class="map-node map-node-three"></span>
          <span class="map-sweep map-sweep-one"></span>
          <span class="map-sweep map-sweep-two"></span>
          <span class="map-label">{trajectory[0].state}</span>
        </div>

        <div class="trajectory-list">
          {
            trajectory.map((item, index) => (
              <article data-build-step={index + 2}>
                <span>{item.step}</span>
                <h2>{item.title}</h2>
                <p>{item.detail}</p>
                <small>{item.state}</small>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="story-section evidence" aria-labelledby="evidence-title" data-scroll-chapter>
      <div class="section-lead">
        <div class="section-heading" data-reveal>
          <span id="evidence-title">working style</span>
          <span>repeatable records</span>
        </div>
        <p class="section-idea" data-reveal>calculation, assumptions, and records stay linked.</p>
      </div>
      <div class="section-details evidence-list">
        <article data-build-step="1">
          <span>01</span>
          <h2>build the calculation.</h2>
          <p>start with local tools, small verification cases, and source history that can be replayed.</p>
        </article>
        <article data-build-step="2">
          <span>02</span>
          <h2>name the assumptions.</h2>
          <p>write down boundary conditions, discretization choices, solver limits, and what changed between runs.</p>
        </article>
        <article data-build-step="3">
          <span>03</span>
          <h2>publish what sharpens it.</h2>
          <p>turn notes, plots, and logs into public pages only when they improve the inspection.</p>
        </article>
      </div>
    </section>

    <section class="split" aria-label="notes and profile">
      <article data-reveal>
        <div class="section-heading">
          <span>notes</span>
          <span><a href="/notes">open log index</a></span>
        </div>
        <p>
          notes hold project decisions, build context, and numerical details once
          they are clear enough to reuse.
        </p>
      </article>

      <article data-reveal>
        <div class="section-heading">
          <span>about</span>
          <span>systems reasoning</span>
        </div>
        <p>
          aerospace engineering, numerical methods, propulsion, and a bias for tools
          that keep the reasoning visible.
        </p>
      </article>
    </section>
  </main>
</BaseLayout>
