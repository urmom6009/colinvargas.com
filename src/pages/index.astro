---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    title: "adaptive cfd solver",
    meta: "thesis / amrex / c++",
    status: "active notebook",
    desc: "Thesis work that starts with scalar advection and makes each solver choice testable, visible, and defensible.",
    lens: "mesh, state, flux, update",
    signal: "small cases before big claims",
    href: "/work/adaptive-cfd-solver"
  },
  {
    title: "scramjet analysis tool",
    meta: "python / propulsion / parametric analysis",
    status: "writeup pending",
    desc: "A propulsion trade-space tool for turning assumptions, sweeps, and trends into plots that can be argued with.",
    lens: "assumption, sweep, trend",
    signal: "make the trade visible",
    href: "/work/scramjet-analysis-tool"
  },
  {
    title: "compressible flow project",
    meta: "numerical methods / visualization / paraview",
    status: "archive pending",
    desc: "Finite-volume simulation work where the useful artifact is not just the plot, but the record around it.",
    lens: "finite-volume inspection",
    signal: "figures with provenance",
    href: "/work/compressible-flow-project"
  }
];

const solverCases = [
  {
    id: "baseline",
    label: "baseline",
    title: "AMReX solver development",
    copy: "Start plain enough that every boundary condition and update can be inspected.",
    scheme: "fv / explicit",
    case: "smooth pulse",
    cfl: "0.42",
    state: "stable margin",
    bars: [42, 68, 55]
  },
  {
    id: "refine",
    label: "refine",
    title: "mesh refinement pass",
    copy: "Tighten the same case and watch which numerical choices start to matter.",
    scheme: "fv / limited",
    case: "refined mesh",
    cfl: "0.31",
    state: "low dissipation",
    bars: [58, 76, 63]
  },
  {
    id: "stress",
    label: "stress",
    title: "stability inspection",
    copy: "Push the step size until the readout stops pretending everything is fine.",
    scheme: "fv / explicit",
    case: "steep front",
    cfl: "0.88",
    state: "watch boundary",
    bars: [74, 46, 82]
  }
];

const readout = [
  { label: "scheme", key: "scheme", value: solverCases[0].scheme },
  { label: "case", key: "case", value: solverCases[0].case },
  { label: "cfl", key: "cfl", value: solverCases[0].cfl }
];

const trajectory = [
  {
    step: "01",
    title: "make it inspectable",
    detail: "Keep the first cases small enough that a mistake has nowhere to hide.",
    state: "case is small on purpose"
  },
  {
    step: "02",
    title: "separate the hard parts",
    detail: "Let mesh, state, flux, and update paths carry their own responsibilities.",
    state: "complexity has addresses"
  },
  {
    step: "03",
    title: "leave a record",
    detail: "Publish notes and figures when they explain the decision, not just the result.",
    state: "evidence before polish"
  }
];

const signal = [
  { label: "numerics", value: "stability before performance theater" },
  { label: "propulsion", value: "trade spaces over hunches" },
  { label: "software", value: "systems that can be reopened later" }
];

const links = [
  { label: "github", href: "https://github.com/colinvargas" },
  { label: "linkedin", href: "https://www.linkedin.com/in/colinvargas" },
  { label: "email", href: "mailto:hello@colinvargas.com" }
];
---

<BaseLayout>
  <div class="field" aria-hidden="true">
    <span class="mach mach-one"></span>
    <span class="mach mach-two"></span>
    <span class="patch patch-one"></span>
    <span class="patch patch-two"></span>
    <span class="trace trace-one"></span>
    <span class="trace trace-two"></span>
  </div>

  <header class="site-header">
    <a class="brand" href="/" aria-label="colin vargas home">colin vargas</a>
    <nav aria-label="Primary navigation">
      <a href="/work">work</a>
      <a href="/notes">notes</a>
      <a href="/resume">resume</a>
      <a href="/about">about</a>
      <a href="/contact">contact</a>
    </nav>
  </header>

  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="hero-kicker">computational aerospace / numerical methods / propulsion</p>
          <h1 id="hero-title">colin vargas</h1>
          <p class="intro">
            I build evidence-first aerospace software: numerical tools, solver
            experiments, and project records that make physical behavior easier
            to inspect.
          </p>
          <p class="hero-stance">
            The throughline is taste under constraint: make the math visible,
            make the code readable, and make the claim earn its keep.
          </p>
        </div>

        <aside class="hero-panel" aria-label="Interactive solver status" data-solver-lab>
          <div class="panel-kicker">
            <span>solver lab</span>
            <span data-solver-state>{solverCases[0].state}</span>
          </div>
          <div class="solver-tabs" aria-label="Solver case selector">
            {
              solverCases.map((item, index) => (
                <button
                  type="button"
                  class:list={["solver-tab", { "is-active": index === 0 }]}
                  aria-pressed={index === 0 ? "true" : "false"}
                  data-solver-case={item.id}
                  data-title={item.title}
                  data-copy={item.copy}
                  data-scheme={item.scheme}
                  data-case={item.case}
                  data-cfl={item.cfl}
                  data-state={item.state}
                  data-bars={item.bars.join(",")}
                >
                  {item.label}
                </button>
              ))
            }
          </div>
          <strong data-solver-title>{solverCases[0].title}</strong>
          <p data-solver-copy>{solverCases[0].copy}</p>

          <div class="solver-readout" aria-label="Solver readout">
            <div class="readout-plot" aria-hidden="true">
              {solverCases[0].bars.map((height) => <span style={`--readout-height: ${height}%`}></span>)}
            </div>
            <dl>
              {
                readout.map((item) => (
                  <div>
                    <dt>{item.label}</dt>
                    <dd data-solver-field={item.key}>{item.value}</dd>
                  </div>
                ))
              }
            </dl>
          </div>
        </aside>
      </div>

      <div class="flow-lab" aria-label="Animated flow field preview">
        <div class="flow-orbit" aria-hidden="true">
          <span class="orbit-ring orbit-ring-one"></span>
          <span class="orbit-ring orbit-ring-two"></span>
          <span class="orbit-dot orbit-dot-one"></span>
          <span class="orbit-dot orbit-dot-two"></span>
          <span class="orbit-dot orbit-dot-three"></span>
        </div>

        <div class="flow-copy">
          <span>working surface</span>
          <strong>measure, compare, explain</strong>
          <p>A quiet instrument panel for the habits behind the work.</p>
        </div>

        <div class="flow-tiles" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
          <span></span>
          <span></span>
          <span></span>
        </div>
      </div>

      <ul class="tags" aria-label="Technical focus areas">
        <li>amrex</li>
        <li>c++</li>
        <li>finite volume</li>
        <li>adaptive mesh refinement</li>
        <li>verification</li>
      </ul>
    </section>

    <section class="signature" aria-labelledby="signature-title">
      <div class="signature-copy">
        <div class="section-heading">
          <span id="signature-title">signal</span>
          <span>engineering taste</span>
        </div>
        <p>
          The interesting problems live where the math, the machine, and the
          physical system all get a vote.
        </p>
      </div>

      <div class="signature-board" aria-label="Technical signal board">
        <div class="signature-equation">
          <span>u_t + div F(u) = 0</span>
          <span>dt &lt;= cfl * dx / max(|lambda|)</span>
        </div>
        <div class="signature-wave" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
          <span></span>
        </div>
        <dl>
          {
            signal.map((item) => (
              <div>
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <section class="section" id="work" aria-labelledby="work-title">
      <div class="section-heading">
        <span id="work-title">selected work</span>
        <span><a href="/work">full index</a></span>
      </div>

      <div class="project-grid">
        {
          projects.map((project) => (
            <a
              class="project-card"
              href={project.href}
              data-project-card
              data-project-lens={project.lens}
              data-project-signal={project.signal}
            >
              <span class="project-meta">{project.meta}</span>
              <h2>{project.title}</h2>
              <p>{project.desc}</p>
              <span class="project-lens">{project.lens}</span>
              <span class="project-status">{project.status}</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="focus" aria-labelledby="focus-title">
      <div class="section-heading">
        <span id="focus-title">current focus</span>
        <span>thesis track</span>
      </div>
      <p>
        I am building the solver, the verification trail, and the public record
        together so the work can be reopened without depending on memory.
      </p>
    </section>

    <section class="trajectory" aria-labelledby="trajectory-title">
      <div class="section-heading">
        <span id="trajectory-title">solver trajectory</span>
        <span>from case to record</span>
      </div>

      <div class="trajectory-grid" data-trajectory>
        <div class="trajectory-map" aria-hidden="true" data-trajectory-map>
          <span class="map-line"></span>
          <span class="map-node map-node-one"></span>
          <span class="map-node map-node-two"></span>
          <span class="map-node map-node-three"></span>
          <span class="map-sweep map-sweep-one"></span>
          <span class="map-sweep map-sweep-two"></span>
          <span class="map-label" data-trajectory-state>{trajectory[0].state}</span>
        </div>

        <div class="trajectory-list">
          {
            trajectory.map((item, index) => (
              <article class:list={[{ "is-active": index === 0 }]} data-trajectory-step>
                <button type="button" data-state={item.state} aria-pressed={index === 0 ? "true" : "false"}>
                  <span>{item.step}</span>
                  <span class="trajectory-title">{item.title}</span>
                  <span class="trajectory-detail">{item.detail}</span>
                </button>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="evidence" aria-labelledby="evidence-title">
      <div class="section-heading">
        <span id="evidence-title">working style</span>
        <span>repeatable records</span>
      </div>
      <div class="evidence-list">
        <article>
          <span>01</span>
          <h2>Build the calculation.</h2>
          <p>Start with local tools, small verification cases, and source history that can be replayed.</p>
        </article>
        <article>
          <span>02</span>
          <h2>Name the assumptions.</h2>
          <p>Write down boundary conditions, discretization choices, solver limits, and what changed between runs.</p>
        </article>
        <article>
          <span>03</span>
          <h2>Publish what sharpens it.</h2>
          <p>Turn notes, plots, and logs into public pages only when they improve the inspection.</p>
        </article>
      </div>
    </section>

    <section class="split" aria-label="Notes and profile">
      <article>
        <div class="section-heading">
          <span>notes</span>
          <span><a href="/notes">open log index</a></span>
        </div>
        <p>
          Notes are not a content treadmill here. They are where project
          decisions, build scars, and numerical context get cleaned into
          something reusable.
        </p>
      </article>

      <article>
        <div class="section-heading">
          <span>about</span>
          <span>systems reasoning</span>
        </div>
        <p>
          Aerospace engineering, numerical methods, propulsion, and a bias for
          tools that show their work instead of hiding behind a clean screenshot.
        </p>
      </article>
    </section>
  </main>

  <footer>
    <span>america/phoenix</span>
    <div class="footer-links">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </div>
  </footer>

  <script is:inline>
    (() => {
      const solver = document.querySelector("[data-solver-lab]");
      if (solver) {
        const title = solver.querySelector("[data-solver-title]");
        const copy = solver.querySelector("[data-solver-copy]");
        const state = solver.querySelector("[data-solver-state]");
        const bars = Array.from(solver.querySelectorAll(".readout-plot span"));
        const fields = {
          scheme: solver.querySelector('[data-solver-field="scheme"]'),
          case: solver.querySelector('[data-solver-field="case"]'),
          cfl: solver.querySelector('[data-solver-field="cfl"]')
        };

        const setCase = (button) => {
          solver.querySelectorAll("[data-solver-case]").forEach((item) => {
            const active = item === button;
            item.classList.toggle("is-active", active);
            item.setAttribute("aria-pressed", String(active));
          });

          title.textContent = button.dataset.title;
          copy.textContent = button.dataset.copy;
          state.textContent = button.dataset.state;
          fields.scheme.textContent = button.dataset.scheme;
          fields.case.textContent = button.dataset.case;
          fields.cfl.textContent = button.dataset.cfl;

          button.dataset.bars.split(",").forEach((height, index) => {
            bars[index]?.style.setProperty("--readout-height", `${height}%`);
          });
        };

        solver.addEventListener("click", (event) => {
          const button = event.target.closest("[data-solver-case]");
          if (button) {
            setCase(button);
          }
        });
      }

      const trajectory = document.querySelector("[data-trajectory]");
      if (trajectory) {
        const steps = Array.from(trajectory.querySelectorAll("[data-trajectory-step]"));
        const state = trajectory.querySelector("[data-trajectory-state]");
        const map = trajectory.querySelector("[data-trajectory-map]");

        const setStep = (article) => {
          steps.forEach((step, index) => {
            const active = step === article;
            step.classList.toggle("is-active", active);
            step.querySelector("button").setAttribute("aria-pressed", String(active));
            if (active) {
              map.dataset.activeStep = String(index + 1);
              state.textContent = step.querySelector("button").dataset.state;
            }
          });
        };

        trajectory.addEventListener("click", (event) => {
          const article = event.target.closest("[data-trajectory-step]");
          if (article) {
            setStep(article);
          }
        });
      }
    })();
  </script>
</BaseLayout>
