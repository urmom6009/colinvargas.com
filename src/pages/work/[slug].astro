---
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [
    {
      params: { slug: "adaptive-cfd-solver" },
      props: {
        title: "adaptive cfd solver",
        meta: "amrex / c++ / finite volume",
        status: "active build log",
        summary:
          "a thesis-track solver path from scalar advection toward adaptive, higher-order flow capabilities.",
        next: "add build notes, verification cases, plots, and solver architecture diagrams."
      }
    },
    {
      params: { slug: "scramjet-analysis-tool" },
      props: {
        title: "scramjet analysis tool",
        meta: "python / propulsion / parametric analysis",
        status: "writeup pending",
        summary:
          "a computational analysis tool for exploring propulsion trade spaces and performance trends.",
        next: "add methodology, sample sweeps, plots, and the clearest takeaways."
      }
    },
    {
      params: { slug: "compressible-flow-project" },
      props: {
        title: "compressible flow project",
        meta: "numerical methods / visualization / paraview",
        status: "archive pending",
        summary:
          "finite-volume simulations and post-processing workflows for understanding compressible flow behavior.",
        next: "add simulation setup, visual outputs, and notes on numerical behavior."
      }
    }
  ];
}

const project = Astro.props;
---

<BaseLayout title={`${project.title} - colin vargas`}>
  <header class="site-header">
    <a class="brand" href="/" aria-label="colin vargas home">colin vargas</a>
    <nav aria-label="primary navigation">
      <a href="/work" aria-current="page">work</a>
      <a href="/notes">notes</a>
      <a href="/resume">resume</a>
      <a href="/about">about</a>
      <a href="/contact">contact</a>
    </nav>
  </header>

  <main>
    <section class="pending-page page-scene" aria-labelledby="pending-title" data-scroll-chapter>
      <div class="section-heading">
        <span>{project.meta}</span>
        <span>{project.status}</span>
      </div>

      <div class="pending-grid">
        <div>
          <h1 id="pending-title">{project.title}</h1>
          <p>{project.summary}</p>
        </div>

        <aside class="pending-note">
          <span>not ready yet</span>
          <p>{project.next}</p>
        </aside>
      </div>

      <div class="pending-actions">
        <a href="/work" data-build-step="1">back to selected work</a>
        <a href="/resume" data-build-step="2">resume index</a>
        <a href="/notes" data-build-step="3">view notes index</a>
      </div>
    </section>
  </main>
</BaseLayout>
