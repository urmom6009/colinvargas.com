---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="notes - colin vargas">
  <header class="site-header">
    <a class="brand" href="/" aria-label="colin vargas home">colin vargas</a>
    <nav aria-label="primary navigation">
      <a href="/work">work</a>
      <a href="/notes" aria-current="page">notes</a>
      <a href="/resume">resume</a>
      <a href="/about">about</a>
      <a href="/contact">contact</a>
    </nav>
  </header>

  <main>
    <section class="pending-page" aria-labelledby="notes-title">
      <div class="section-heading">
        <span>notes</span>
        <span>field notes pending</span>
      </div>

      <div class="pending-grid">
        <div>
          <h1 id="notes-title">notes will publish when they earn the space.</h1>
          <p>
            the logging workflow is wired into the repo. public entries will
            appear once the build context, figures, and decisions are clear
            enough to be useful.
          </p>
        </div>

        <aside class="pending-note">
          <span>how entries are made</span>
          <p>
            new notes are created from any local repository with
            <code>portfolio-log "topic"</code>, then promoted when the record
            explains something worth keeping.
          </p>
        </aside>
      </div>

      <div class="pending-actions">
        {[
          { href: "/", label: "back home" },
          { href: "/work", label: "selected work" },
          { href: "/resume", label: "resume index" }
        ].map((link, index) => (
          <a href={link.href} data-build-step={index + 1}>{link.label}</a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
