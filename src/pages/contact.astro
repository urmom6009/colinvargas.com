---
import BaseLayout from "../layouts/BaseLayout.astro";

const contacts = [
  { label: "github", href: "https://github.com/colinvargas", detail: "source, notes, and project history" },
  { label: "linkedin", href: "https://www.linkedin.com/in/colinvargas", detail: "profile and professional context" },
  { label: "email", href: "mailto:hello@colinvargas.com", detail: "hello@colinvargas.com" }
];
---

<BaseLayout title="contact - colin vargas">
  <header class="site-header">
    <a class="brand" href="/" aria-label="colin vargas home">colin vargas</a>
    <nav aria-label="primary navigation">
      <a href="/work">work</a>
      <a href="/notes">notes</a>
      <a href="/resume">resume</a>
      <a href="/about">about</a>
      <a href="/contact" aria-current="page">contact</a>
    </nav>
  </header>

  <main>
    <section class="resume-hero" aria-labelledby="contact-title">
      <div class="section-heading">
        <span>contact</span>
        <span>open channels</span>
      </div>

      <div class="resume-hero-grid">
        <div>
          <h1 id="contact-title">reach out with something concrete.</h1>
          <p>
            email is best for direct notes, linkedin is best for profile context,
            and github is best for source history as the project record comes online.
          </p>
        </div>

        <aside>
          <span>timezone</span>
          <strong>america/phoenix</strong>
          <p>cfd, propulsion analysis, numerical methods, aerospace software, and well-framed technical questions are welcome.</p>
        </aside>
      </div>
    </section>

    <section class="resume-section resume-contact" aria-labelledby="contact-links-title">
      <div class="section-heading">
        <span id="contact-links-title">links</span>
        <span>open channels</span>
      </div>

      <div class="resume-contact-grid">
        {
          contacts.map((contact, index) => (
            <a href={contact.href} data-build-step={index + 1}>
              <span>{contact.label}</span>
              <strong>{contact.detail}</strong>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
